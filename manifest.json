{
  "manifest_version": 3,
  "name": "达人外联助手",
  "description": "AI-powered multi-platform influencer outreach remote control",
  "version": "2.1.0",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://*.douyin.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.xhscdn.com/*",
    "https://outreach-hub-lac.vercel.app/*",
    "https://kcdaaavcnvbzzzvceenb.supabase.co/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.douyin.com/*", "https://douyin.com/*"],
      "js": [
        "content/shared/selector-helpers.js",
        "content/shared/base-extractors.js",
        "content/shared/base-actions.js",
        "content/douyin/selectors.js",
        "content/douyin/extractors.js",
        "content/douyin/actions.js",
        "content/douyin/main.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.xiaohongshu.com/*", "https://xiaohongshu.com/*"],
      "js": [
        "content/shared/selector-helpers.js",
        "content/shared/base-extractors.js",
        "content/shared/base-actions.js",
        "content/xiaohongshu/selectors.js",
        "content/xiaohongshu/extractors.js",
        "content/xiaohongshu/actions.js",
        "content/xiaohongshu/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/logo.png",
      "48": "icons/logo.png"
    },
    "default_title": "达人外联助手"
  }
}
